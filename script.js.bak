const body = document.body;
const titleEl = document.getElementById("sceneTitle");
const descriptionEl = document.getElementById("sceneDescription");
const choiceRow = document.getElementById("choiceRow");
const choiceDivider = document.getElementById("choiceDivider");
const choiceButtons = document.querySelectorAll(".choice");
const moodLabel = document.getElementById("moodLabel");
const sceneImage = document.getElementById("sceneImage");
const endingPanel = document.getElementById("endingPanel");
const endingBadge = document.getElementById("endingBadge");
const endingHint = document.getElementById("endingHint");
const restartBtn = document.getElementById("restartBtn");

let currentSceneId = "start";

function applyMood(mood = "calm") {
  moodClasses.forEach((cls) => body.classList.remove(cls));
  body.classList.add(`mood-${mood}`);
  moodLabel.textContent = moodLabels[mood] ?? "Unknown";
}

function renderScene(sceneId) {
  const scene = scenes[sceneId];
  if (!scene) {
    console.warn(`Scene ${sceneId} is missing.`);
    return;
  }

  currentSceneId = sceneId;
  titleEl.textContent = scene.title;
  descriptionEl.textContent = scene.description;
  sceneImage.src = scene.image;
  sceneImage.alt = scene.title;
  applyMood(scene.mood);

  if (scene.isEnding) {
    choiceRow.hidden = true;
    endingBadge.hidden = false;
    endingBadge.textContent = `${scene.endingName} · Ending ${scene.endingNumber}/10`;
    endingHint.hidden = false;
    endingHint.textContent = "No more moves. Hit \"Return to Homeroom\" to restart.";
    endingPanel.hidden = false;
    restartBtn.hidden = false;
  } else {
    endingPanel.hidden = true;
    endingBadge.hidden = true;
    endingHint.hidden = true;
    restartBtn.hidden = true;
    choiceRow.hidden = false;

    const availableChoices = scene.choices?.filter(Boolean) ?? [];
    choiceDivider.style.visibility = availableChoices.length === 2 ? "visible" : "hidden";

    choiceButtons.forEach((button, index) => {
      const choice = scene.choices?.[index];
      if (choice) {
        button.hidden = false;
        button.disabled = false;
        button.textContent = choice.text;
      } else {
        button.hidden = true;
      }
    });
  }
}

choiceButtons.forEach((button, index) => {
  button.addEventListener("click", () => {
    const scene = scenes[currentSceneId];
    const next = scene?.choices?.[index]?.next;
    if (!next) return;
    renderScene(next);
  });
});

restartBtn.addEventListener("click", () => {
  renderScene("start");
});

renderScene("start");
